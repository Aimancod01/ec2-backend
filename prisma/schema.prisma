generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id       String    @id @default(uuid()) @db.Uuid
  name     String
  products Product[]

  @@map("categories")
}

model Product {
  id    String @id @default(uuid()) @db.Uuid
  name  String
  price Float

  categoryId String   @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("products")
}
